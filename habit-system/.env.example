# 养成系统 API 端口（默认 3002）
HABIT_API_PORT=3002

# SQLite 路径（默认 habit-system/data/habit.db）
# HABIT_SQLITE_PATH=data/habit.db

# 计分用本地时区（默认 Asia/Shanghai）
# HABIT_TIMEZONE=Asia/Shanghai

# 前后端同域（Vercel Functions）：前端统一使用相对路径 /api/*
# VITE_HABIT_API_BASE 已废弃（无需配置）

# Supabase（未配置时应用使用本地 Mock 认证 + LocalStorage）
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AI 奖励规划师（至少配置一套）
# OPENAI_API_KEY=sk-...
# OPENAI_REWARD_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_REWARD_MODEL=claude-3-5-haiku-20241022
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_REWARD_MODEL=deepseek-chat
# LLM_PROVIDER=openai
