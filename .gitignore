# 依赖与构建输出
node_modules
dist
.vercel

# 核心安全：屏蔽所有环境配置文件
.env
.env.local
.env.development
.env.production
.env.*.local

# OAuth / 云端凭证（切勿提交，尤其是 Google 等 client_secret json）
*client_secret*.json
*googleusercontent*.json
credentials.json
token.json
*.pem
.id_rsa
*.p12

# 本地数据库与临时文件
data/*.db
data/*.db-shm
data/*.db-wal
*.tsbuildinfo
.DS_Store

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 私人材料（不推送到远程）
简历修改/

