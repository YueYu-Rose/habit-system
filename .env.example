PORT=3001
# SQLITE_PATH=data/app.db

# Toggl Track — https://track.toggl.com/profile
TOGGL_API_TOKEN=
# Optional: IANA timezone for entry_date if Import does not send clientTimeZone (e.g. server-only cron)
# LOCAL_DATE_TZ=Asia/Shanghai

# Google Calendar — enable "Google Calendar API"; OAuth client type: Web application
# Authorized redirect URI in Google Cloud MUST match this value exactly (no trailing slash):
#   http://localhost:3001/api/dev/google-oauth/callback
# Use the SAME OAuth client (ID + secret) for dev token flow and for sync. No spaces in values.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optional override (default is the URI above):
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/dev/google-oauth/callback
# GOOGLE_CALENDAR_ID=primary
#
# If Calendar import returns invalid_grant: regenerate GOOGLE_REFRESH_TOKEN — see README.md → Google Calendar OAuth.
